{
  "routes": [
    { "route": "/.auth/login/github", "statusCode": 403 },
    { "route": "/.auth/*", "allowedRoles": ["anonymous"] },
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 },
    "404": { "redirect": "/", "statusCode": 302 }
  }
}
